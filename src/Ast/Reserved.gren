module Ast.Reserved exposing ( apply, exportRenames, rewriteName )

{-| Rename identifiers that are keywords in Gren but ordinary names in Elm.

**Values / binders / exposing / @docs:** `when` → first free of `when_`,
`when__`, … so we never collide with an existing `when_` (Elm authors often
pre-escape params that way; Elm already forbids shadowing).

**Record fields:** always the fixed escape `when` → `when_`. Fields are a
separate namespace from values, and must match across modules (Internals vs
callers) — occupancy-based field renames would desync payloads.

**Cross-module references:** the occupancy escape is per-module, so module `A`
may rename its exported `when` to `when__` (because `A` also binds `when_`)
while a caller `B` that lacks `when_` would pick `when_`. Resolving a
qualified/exposing-imported reference with the *caller's* map desyncs the call
(`B` emits `A.when_` / `import A exposing (when_)` but `A` exposes `when__`).
So references with a resolved module name (both `A.when` and unqualified
`when` imported from `A`, which the extractor resolves to `A`) and import
`exposing` lists are rewritten from the package-wide export map — the
*defining* module's decision — not the local occupancy map.
-}

import Array exposing ( Array )
import Ast.Types exposing
    ( Declaration(..)
    , Exposing(..)
    , Expr(..)
    , ExposedItem(..)
    , File
    , Import
    , LetDecl(..)
    , ModuleDef
    , NamedRef
    , Pattern(..)
    , RecordFieldType
    , Signature
    , TypeAnn(..)
    )
import Ast.Walk as Walk
import Dict exposing ( Dict )
import Maybe exposing ( Maybe(..) )
import String


type alias RenameMap =
    Dict String String


{-| Rewrite context: `local` is this module's occupancy escape (own binders,
own exposing, own decl names); `package` is the package-wide export map,
keyed `"Module.name"`, holding every module's own reserved-export decisions so
cross-module references resolve to the *defining* module's escaped name.
-}
type alias Ctx =
    { package : Dict String String
    , local : RenameMap
    }


apply : Dict String String -> File -> File
apply packageExports file =
    let
        renames =
            buildRenameMap (collectOccupied file)

        ctx =
            { package = packageExports, local = renames }
    in
    { file
        | moduleDefinition = rewriteModuleDef renames file.moduleDefinition
        , imports = Array.map (rewriteImport ctx) file.imports
        , declarations =
              Array.map (rewriteDeclaration ctx) file.declarations
        , comments = Array.map (rewriteDocsComment renames) file.comments
    }


{-| This module's reserved-word export decisions, keyed `"Module.name"`, for
the package-wide map that keeps cross-module qualified references in sync.
Computed with the exact occupancy `apply` uses, so a module's own package
entry equals its local escape.
-}
exportRenames : File -> Dict String String
exportRenames file =
    let
        moduleName =
            file.moduleDefinition.moduleName
    in
    Dict.foldl
        (\reserved escaped acc ->
            Dict.set (moduleName ++ "." ++ reserved) escaped acc)
        Dict.empty
        (buildRenameMap (collectOccupied file))


{-| Public helper: naive single underscore escape (no occupancy). Prefer `apply`
for full modules so collisions with existing `when_` are avoided.
-}
rewriteName : String -> String
rewriteName name =
    if isReserved name then
        name ++ "_"

    else
        name


rewriteWith : RenameMap -> String -> String
rewriteWith renames name =
    when Dict.get name renames is
        Just target ->
            target

        Nothing ->
            name


{-| Record field names: fixed single `_` escape so all modules agree.
-}
rewriteField : String -> String
rewriteField name =
    if isReserved name then
        name ++ "_"

    else
        name


isReserved : String -> Bool
isReserved name =
    Array.member name reservedWords


reservedWords : Array String
reservedWords =
    [ "when"
    , "is"
    , "as"
    , "type"
    , "alias"
    , "module"
    , "import"
    , "exposing"
    , "port"
    , "if"
    , "then"
    , "else"
    , "let"
    , "in"
    , "case"
    , "of"
    ]


{-| reserved → free escape. Only includes reserved names that appear as idents.
-}
buildRenameMap : Dict String {} -> RenameMap
buildRenameMap occupied =
    Array.foldl
        (\reserved state ->
            if Dict.member reserved state.taken then
                let
                    target =
                        pickFree reserved state.taken
                in
                { map = Dict.set reserved target state.map
                , taken = Dict.set target {} state.taken
                }

            else
                state) { map = Dict.empty, taken = occupied } reservedWords
        |> .map


{-| `when` → try `when_`, then `when__`, … until not in `taken`.
-}
pickFree : String -> Dict String {} -> String
pickFree name taken =
    let
        candidate =
            name ++ "_"
    in
    if Dict.member candidate taken then
        pickFree candidate taken

    else
        candidate

-- COLLECT --------------------------------------------------------------------


occupy : String -> Dict String {} -> Dict String {}
occupy name acc =
    Dict.set name {} acc


collectOccupied : File -> Dict String {}
collectOccupied file =
    let
        fromModule =
            collectExposing file.moduleDefinition.exposing_ Dict.empty

        fromImports =
            Array.foldl collectImport fromModule file.imports
    in
    Array.foldl collectDeclaration fromImports file.declarations


collectImport : Import -> Dict String {} -> Dict String {}
collectImport import_ acc =
    let
        withAlias =
            when import_.alias is
                Just a ->
                    occupy a acc

                Nothing ->
                    acc
    in
    when import_.exposing_ is
        Just exposing_ ->
            collectExposing exposing_ withAlias

        Nothing ->
            withAlias


collectExposing : Exposing -> Dict String {} -> Dict String {}
collectExposing exposing_ acc =
    when exposing_ is
        ExposeAll ->
            acc

        ExposeExplicit items ->
            Array.foldl collectExposedItem acc items


collectExposedItem : ExposedItem -> Dict String {} -> Dict String {}
collectExposedItem item acc =
    when item is
        ExposeInfix name ->
            occupy name acc

        ExposeFunction name ->
            occupy name acc

        ExposeTypeOrAlias name ->
            occupy name acc

        ExposeType { name = name } ->
            occupy name acc


collectDeclaration : Declaration -> Dict String {} -> Dict String {}
collectDeclaration declaration acc =
    when declaration is
        DeclFunction fn ->
            let
                withName =
                    occupy fn.name acc

                withSig =
                    when fn.signature is
                        Just signature ->
                            collectType signature.typeAnnotation withName

                        Nothing ->
                            withName

                withArgs =
                    Array.foldl collectPattern withSig fn.arguments
            in
            collectExpr fn.expression withArgs

        DeclAlias aliasDecl ->
            occupy aliasDecl.name acc
                |> (\a -> Array.foldl occupy a aliasDecl.generics)
                |> collectType aliasDecl.typeAnnotation

        DeclCustomType custom ->
            let
                withType =
                    occupy custom.name acc
                        |> (\a -> Array.foldl occupy a custom.generics)
            in
            Array.foldl
                (\ctor inner ->
                    occupy ctor.name inner
                        |> (\a -> Array.foldl collectType a ctor.arguments))
                withType custom.constructors

        DeclPort signature ->
            occupy signature.name acc
                |> collectType signature.typeAnnotation

        DeclInfix ->
            acc

        DeclDestructure { pattern = pattern, expression = expression } ->
            collectPattern pattern acc
                |> collectExpr expression


collectType : TypeAnn -> Dict String {} -> Dict String {}
collectType typeAnn acc =
    when typeAnn is
        TypeGeneric name ->
            occupy name acc

        TypeTyped { ref = ref, arguments = args } ->
            occupy ref.name acc
                |> (\a -> Array.foldl collectType a args)

        TypeTuple items ->
            Array.foldl collectType acc items

        TypeRecord fields ->
            Array.foldl collectRecordFieldType acc fields

        TypeGenericRecord { extension = ext, fields = fields } ->
            occupy ext acc
                |> (\a -> Array.foldl collectRecordFieldType a fields)

        TypeFunction { left = left, right = right } ->
            collectType left acc
                |> collectType right

        TypeUnit ->
            acc


collectRecordFieldType : RecordFieldType -> Dict String {} -> Dict String {}
collectRecordFieldType field acc =
    occupy field.name acc
        |> collectType field.typeAnnotation


collectPattern : Pattern -> Dict String {} -> Dict String {}
collectPattern pattern acc =
    when pattern is
        PatVar name ->
            occupy name acc

        PatNamed { ref = ref, arguments = args } ->
            occupy ref.name acc
                |> (\a -> Array.foldl collectPattern a args)

        PatAs { pattern = inner, name = name } ->
            collectPattern inner acc
                |> occupy name

        PatRecord fields ->
            Array.foldl occupy acc fields

        PatRecordBind fields ->
            Array.foldl
                (\field inner ->
                    occupy field.name inner
                        |> collectPattern field.pattern) acc fields

        _ ->
            Walk.mapPatternChildren identity pattern
                |> (\_ -> acc)
                |>
                    (\a ->
                    -- structural children
                        when pattern is
                            PatTuple items ->
                                Array.foldl collectPattern a items

                            PatList items ->
                                Array.foldl collectPattern a items

                            PatCons { head = head, tail = tail } ->
                                collectPattern head a
                                    |> collectPattern tail

                            _ ->
                                a)


collectExpr : Expr -> Dict String {} -> Dict String {}
collectExpr expr acc =
    when expr is
        ExprVar ref ->
            occupy ref.name acc

        ExprRecord fields ->
            Array.foldl
                (\field inner ->
                    occupy field.name inner
                        |> collectExpr field.value) acc fields

        ExprAccess { record = record, field = field } ->
            collectExpr record acc
                |> occupy field

        ExprAccessFunction field ->
            occupy field acc

        ExprUpdate { name = name, fields = fields } ->
            occupy name acc
                |>
                    (\a ->
                        Array.foldl
                            (\field inner ->
                                occupy field.name inner
                                    |> collectExpr field.value) a fields)

        _ ->
            Walk.foldExprChildren collectExpr acc expr
                |>
                    (\a ->
                        when expr is
                            ExprLambda
                                { arguments = arguments, expression = body } ->
                                Array.foldl collectPattern a arguments
                                    |> collectExpr body

                            ExprCase { expression = scrutinee, cases = arms } ->
                                collectExpr scrutinee a
                                    |>
                                        (\inner ->
                                            Array.foldl
                                                (\arm acc2 ->
                                                    collectPattern arm.pattern
                                                        acc2
                                                        |> collectExpr arm.body)
                                                inner arms)

                            ExprLet
                                { declarations = declarations
                                , expression = body
                                } ->
                                Array.foldl collectLetDecl a declarations
                                    |> collectExpr body

                            _ ->
                                -- foldExprChildren already walked child exprs for other forms
                                a)


collectLetDecl : LetDecl -> Dict String {} -> Dict String {}
collectLetDecl declaration acc =
    when declaration is
        LetFunction fn ->
            occupy fn.name acc
                |> (\a -> Array.foldl collectPattern a fn.arguments)
                |> collectExpr fn.expression

        LetDestructure { pattern = pattern, expression = expression } ->
            collectPattern pattern acc
                |> collectExpr expression


identity : a -> a
identity x =
    x

-- REWRITE --------------------------------------------------------------------


rewriteModuleDef : RenameMap -> ModuleDef -> ModuleDef
rewriteModuleDef renames moduleDef =
    { moduleDef | exposing_ = rewriteExposing renames moduleDef.exposing_ }


rewriteImport : Ctx -> Import -> Import
rewriteImport ctx import_ =
    { import_
        | alias = Maybe.map (rewriteWith ctx.local) import_.alias
        , exposing_ =
              Maybe.map (rewriteImportExposing ctx.package import_.moduleName)
                  import_.exposing_
    }


{-| An `import A exposing (when)` names A's *exports*, so it must follow A's
own escape decision (from the package map), not the caller's occupancy map.
-}
rewriteImportExposing : Dict String String -> String -> Exposing -> Exposing
rewriteImportExposing packageExports moduleName exposing_ =
    when exposing_ is
        ExposeAll ->
            ExposeAll

        ExposeExplicit items ->
            ExposeExplicit
                (Array.map (rewriteImportExposedItem packageExports moduleName)
                    items)


rewriteImportExposedItem :
    Dict String String -> String -> ExposedItem -> ExposedItem
rewriteImportExposedItem packageExports moduleName item =
    let
        resolve name =
            when Dict.get (moduleName ++ "." ++ name) packageExports is
                Just escaped ->
                    escaped

                Nothing ->
                    name
    in
    when item is
        ExposeInfix name ->
            ExposeInfix name

        ExposeFunction name ->
            ExposeFunction (resolve name)

        ExposeTypeOrAlias name ->
            ExposeTypeOrAlias (resolve name)

        ExposeType { name = name, open = open } ->
            ExposeType { name = resolve name, open = open }


rewriteExposing : RenameMap -> Exposing -> Exposing
rewriteExposing renames exposing_ =
    when exposing_ is
        ExposeAll ->
            ExposeAll

        ExposeExplicit items ->
            ExposeExplicit (Array.map (rewriteExposedItem renames) items)


rewriteExposedItem : RenameMap -> ExposedItem -> ExposedItem
rewriteExposedItem renames item =
    when item is
        ExposeInfix name ->
            ExposeInfix name

        ExposeFunction name ->
            ExposeFunction (rewriteWith renames name)

        ExposeTypeOrAlias name ->
            ExposeTypeOrAlias (rewriteWith renames name)

        ExposeType { name = name, open = open } ->
            ExposeType { name = rewriteWith renames name, open = open }


rewriteDeclaration : Ctx -> Declaration -> Declaration
rewriteDeclaration ctx declaration =
    when declaration is
        DeclFunction fn ->
            DeclFunction
                { fn
                    | name = rewriteWith ctx.local fn.name
                    , signature =
                          Maybe.map (rewriteSignature ctx) fn.signature
                    , arguments =
                          Array.map (rewritePattern ctx) fn.arguments
                    , expression = rewriteExpr ctx fn.expression
                }

        DeclAlias aliasDecl ->
            DeclAlias
                { aliasDecl
                    | name = rewriteWith ctx.local aliasDecl.name
                    , generics =
                          Array.map (rewriteWith ctx.local) aliasDecl.generics
                    , typeAnnotation =
                          rewriteType ctx aliasDecl.typeAnnotation
                }

        DeclCustomType custom ->
            DeclCustomType
                { custom
                    | name = rewriteWith ctx.local custom.name
                    , generics = Array.map (rewriteWith ctx.local) custom.generics
                    , constructors =
                          Array.map
                              (\ctor ->
                                  { name = rewriteWith ctx.local ctor.name
                                  , arguments =
                                      Array.map (rewriteType ctx)
                                          ctor.arguments
                                  }) custom.constructors
                }

        DeclPort signature ->
            DeclPort (rewriteSignature ctx signature)

        DeclInfix ->
            DeclInfix

        DeclDestructure { pattern = pattern, expression = expression } ->
            DeclDestructure
                { pattern = rewritePattern ctx pattern
                , expression = rewriteExpr ctx expression
                }


rewriteSignature : Ctx -> Signature -> Signature
rewriteSignature ctx signature =
    { name = rewriteWith ctx.local signature.name
    , typeAnnotation = rewriteType ctx signature.typeAnnotation
    }


rewriteType : Ctx -> TypeAnn -> TypeAnn
rewriteType ctx typeAnn =
    when typeAnn is
        TypeGeneric name ->
            TypeGeneric (rewriteWith ctx.local name)

        TypeTyped { ref = ref, arguments = args } ->
            TypeTyped
                { ref = rewriteRef ctx ref
                , arguments = Array.map (rewriteType ctx) args
                }

        TypeUnit ->
            TypeUnit

        TypeTuple items ->
            TypeTuple (Array.map (rewriteType ctx) items)

        TypeRecord fields ->
            TypeRecord (Array.map (rewriteRecordFieldType ctx) fields)

        TypeGenericRecord { extension = ext, fields = fields } ->
            TypeGenericRecord
                { extension = rewriteWith ctx.local ext
                , fields = Array.map (rewriteRecordFieldType ctx) fields
                }

        TypeFunction { left = left, right = right } ->
            TypeFunction
                { left = rewriteType ctx left
                , right = rewriteType ctx right
                }


rewriteRecordFieldType : Ctx -> RecordFieldType -> RecordFieldType
rewriteRecordFieldType ctx field =
    { name = rewriteField field.name
    , typeAnnotation = rewriteType ctx field.typeAnnotation
    }


rewritePattern : Ctx -> Pattern -> Pattern
rewritePattern ctx pattern =
    when pattern is
        PatVar name ->
            PatVar (rewriteWith ctx.local name)

        PatNamed { ref = ref, arguments = args } ->
            PatNamed
                { ref = rewriteRef ctx ref
                , arguments = Array.map (rewritePattern ctx) args
                }

        PatAs { pattern = inner, name = name } ->
            PatAs
                { pattern = rewritePattern ctx inner
                , name = rewriteWith ctx.local name
                }

        PatRecord fields ->
            PatRecord (Array.map rewriteField fields)

        PatRecordBind fields ->
            PatRecordBind
                (Array.map
                    (\field ->
                        { name = rewriteField field.name
                        , pattern = rewritePattern ctx field.pattern
                        }) fields)

        _ ->
            Walk.mapPatternChildren (rewritePattern ctx) pattern


rewriteExpr : Ctx -> Expr -> Expr
rewriteExpr ctx expr =
    when expr is
        ExprVar ref ->
            ExprVar (rewriteRef ctx ref)

        ExprRecord fields ->
            ExprRecord
                (Array.map
                    (\field ->
                        { name = rewriteField field.name
                        , value = rewriteExpr ctx field.value
                        }) fields)

        ExprAccess { record = record, field = field } ->
            ExprAccess
                { record = rewriteExpr ctx record
                , field = rewriteField field
                }

        ExprAccessFunction field ->
            ExprAccessFunction (rewriteField field)

        ExprUpdate { name = name, fields = fields } ->
            ExprUpdate
                { name = rewriteWith ctx.local name
                , fields =
                    Array.map
                        (\field ->
                            { name = rewriteField field.name
                            , value = rewriteExpr ctx field.value
                            }) fields
                }

        _ ->
            Walk.mapExprChildrenWithPatterns (rewriteExpr ctx)
                (rewritePattern ctx) expr


rewriteDocsComment : RenameMap -> String -> String
rewriteDocsComment renames comment =
    comment
        |> String.split "\n"
        |> Array.map (rewriteDocsLine renames)
        |> String.join "\n"


rewriteDocsLine : RenameMap -> String -> String
rewriteDocsLine renames line =
    if String.contains "@docs" line then
        rewriteDocsTokens renames line

    else
        line


rewriteDocsTokens : RenameMap -> String -> String
rewriteDocsTokens renames line =
    let
        parts =
            String.split " " line
    in
    parts
        |> Array.map
            (\token ->
                let
                    bare =
                        if String.endsWith "," token then
                            String.dropLast 1 token

                        else
                            token

                    rewritten =
                        rewriteWith renames bare
                in
                -- Always reattach a trailing comma when the source token had
                -- one. Gren docs requires `@docs a, b, c`; dropping commas
                -- when the name is unchanged makes nearly every package fail
                -- verification with DOCS MISTAKE.
                if String.endsWith "," token then
                    rewritten ++ ","

                else
                    rewritten)
        |> String.join " "


rewriteLetDecl : Ctx -> LetDecl -> LetDecl
rewriteLetDecl ctx declaration =
    when declaration is
        LetFunction fn ->
            LetFunction
                { fn
                    | name = rewriteWith ctx.local fn.name
                    , arguments =
                          Array.map (rewritePattern ctx) fn.arguments
                    , expression = rewriteExpr ctx fn.expression
                }

        LetDestructure _ ->
            Walk.mapLetDecl (rewriteExpr ctx) (rewritePattern ctx)
                declaration


{-| A bare reference (`moduleName = Nothing`) is a local/own name → the local
occupancy map. A reference the extractor resolved to a module (`Just m`, both
`m.name` and unqualified names imported from `m`) → `m`'s own export decision
from the package map, so the caller never disagrees with the callee. Names the
package map does not carry (external Gren deps, non-reserved names) pass
through unchanged.
-}
rewriteRef : Ctx -> NamedRef -> NamedRef
rewriteRef ctx ref =
    { moduleName = ref.moduleName
    , name =
        when ref.moduleName is
            Nothing ->
                rewriteWith ctx.local ref.name

            Just moduleName ->
                when Dict.get (moduleName ++ "." ++ ref.name) ctx.package is
                    Just escaped ->
                        escaped

                    Nothing ->
                        ref.name
    }
