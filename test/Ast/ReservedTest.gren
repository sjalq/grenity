module Ast.ReservedTest exposing (tests)

{-| Reserved rename must not collide with existing `when_` binders.
-}

import Array exposing (Array)
import Ast.Print as Print
import Ast.Reserved as Reserved
import Ast.Types exposing
    ( Declaration(..)
    , ExposedItem(..)
    , Exposing(..)
    , Expr(..)
    , File
    , ModuleKind(..)
    , Pattern(..)
    )
import Dict
import String


type alias TestResult =
    { name : String
    , passed : Bool
    , details : String
    }


tests : Array TestResult
tests =
    [ reservedEscapesAroundExistingUnderscore
    , docsRewriteKeepsCommasWhenNameUnchanged
    , crossModuleReferenceFollowsDefiningModuleEscape
    ]


{-| `@docs a, b, c` must keep commas even when no reserved rename applies.
Dropping them makes `gren docs` fail with DOCS MISTAKE on almost every package.
-}
docsRewriteKeepsCommasWhenNameUnchanged : TestResult
docsRewriteKeepsCommasWhenNameUnchanged =
    let
        base =
            emptyFile []

        file =
            { base
                | comments =
                    [ "{-| Module.\n\n@docs Response, res, andThen\n\n-}"
                    ]
            }

        printed =
            file
                |> Reserved.apply Dict.empty
                |> Print.print

        passed =
            String.contains "@docs Response, res, andThen" printed
    in
    outcome
        "reserved @docs rewrite keeps commas when names are unchanged"
        passed
        ("printed:\n" ++ printed)


{-| Elm already avoids shadowing: top-level `when`, param `when_`.
Naive `when` → `when_` collides; free name must be `when__`.
-}
reservedEscapesAroundExistingUnderscore : TestResult
reservedEscapesAroundExistingUnderscore =
    let
        file =
            emptyFile
                [ DeclFunction
                    { name = "when"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprRecord
                            [ { name = "editingOrBlurred"
                              , value =
                                    ExprApplication
                                        [ ExprVar { moduleName = Nothing, name = "init" }
                                        , ExprVar { moduleName = Nothing, name = "EditingOrBlurred" }
                                        ]
                              }
                            ]
                    }
                , DeclFunction
                    { name = "init"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "when_", PatVar "func" ]
                    , expression =
                        ExprRecord
                            [ { name = "func"
                              , value = ExprVar { moduleName = Nothing, name = "func" }
                              }
                            , { name = "when"
                              , value = ExprVar { moduleName = Nothing, name = "when_" }
                              }
                            ]
                    }
                ]

        printed =
            file
                |> Reserved.apply Dict.empty
                |> Print.print

        passed =
            -- value when → when__; param when_ kept; field when → when_ (fixed)
            String.contains "when__ =" printed
                && String.contains "init when_ func =" printed
                && String.contains "when_ = when_" printed
                && not (String.contains "init when__ " printed)
                && not (String.contains "when__ = when_" printed)
    in
    outcome
        "reserved escape skips existing when_ binder"
        passed
        ("printed:\n" ++ printed)


{-| D18: occupancy escapes are per-module. `Lib` exports `when` but also binds
`when_`, so it escalates its export to `when__`; a caller `Caller` that lacks
`when_` would pick `when_` on its own. Rewriting the qualified reference and
the `import Lib exposing (when)` list from `Caller`'s map would emit
`Lib.when_` / `exposing (when_)` while `Lib` exposes `when__` — a broken call.
With the package export map, both the qualified ref and the import follow
`Lib`'s decision (`when__`), matching what `Lib` emits.
-}
crossModuleReferenceFollowsDefiningModuleEscape : TestResult
crossModuleReferenceFollowsDefiningModuleEscape =
    let
        -- `Lib` exposes `when`, and internally binds `when_`, forcing `when`
        -- to escalate to `when__` in `Lib` only.
        lib =
            { schemaVersion = 1
            , moduleDefinition =
                { kind = NormalModule
                , moduleName = "Lib"
                , exposing_ = ExposeExplicit [ ExposeFunction "when" ]
                }
            , comments = []
            , imports = []
            , declarations =
                [ DeclFunction
                    { name = "when_"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "n" ]
                    , expression = ExprVar { moduleName = Nothing, name = "n" }
                    }
                , DeclFunction
                    { name = "when"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = [ PatVar "x" ]
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Nothing, name = "when_" }
                            , ExprVar { moduleName = Nothing, name = "x" }
                            ]
                    }
                ]
            }

        -- `Caller` imports `Lib exposing (when)` and references it both
        -- unqualified (resolved to `Lib` by the extractor) and qualified.
        -- It has no `when_`, so on its own it would pick `when_`.
        caller =
            { schemaVersion = 1
            , moduleDefinition =
                { kind = NormalModule
                , moduleName = "Caller"
                , exposing_ = ExposeExplicit [ ExposeFunction "total" ]
                }
            , comments = []
            , imports =
                [ { moduleName = "Lib"
                  , alias = Nothing
                  , exposing_ = Just (ExposeExplicit [ ExposeFunction "when" ])
                  }
                ]
            , declarations =
                [ DeclFunction
                    { name = "total"
                    , documentation = Nothing
                    , signature = Nothing
                    , arguments = []
                    , expression =
                        ExprApplication
                            [ ExprVar { moduleName = Just "Lib", name = "when" }
                            , ExprVar { moduleName = Nothing, name = "x" }
                            ]
                    }
                ]
            }

        packageExports =
            Dict.union
                (Reserved.exportRenames lib)
                (Reserved.exportRenames caller)

        libDecision =
            Dict.get "Lib.when" packageExports
                |> Maybe.withDefault "<missing>"

        libPrinted =
            Print.print (Reserved.apply packageExports lib)

        callerPrinted =
            Print.print (Reserved.apply packageExports caller)

        passed =
            -- Lib escalates its own export to `when__`.
            libDecision
                == "when__"
                -- Lib emits the escalated export.
                && String.contains "when__" libPrinted
                -- Caller's qualified ref follows Lib, not its own occupancy.
                && String.contains "Lib.when__" callerPrinted
                -- Caller's import `exposing` list follows Lib too.
                && String.contains "when__" callerPrinted
                -- The desynced single-underscore form must NOT appear.
                && not (String.contains "Lib.when_ " callerPrinted)
    in
    outcome
        "cross-module reference follows defining module's reserved escape"
        passed
        ("libDecision: "
            ++ libDecision
            ++ "\nlibPrinted:\n"
            ++ libPrinted
            ++ "\ncallerPrinted:\n"
            ++ callerPrinted
        )


emptyFile : Array Declaration -> File
emptyFile declarations =
    { schemaVersion = 1
    , moduleDefinition =
        { kind = NormalModule
        , moduleName = "Validation"
        , exposing_ = ExposeAll
        }
    , comments = []
    , imports = []
    , declarations = declarations
    }


outcome : String -> Bool -> String -> TestResult
outcome name passed details =
    { name = name
    , passed = passed
    , details =
        if passed then
            ""

        else
            details
    }
